---
// ChartCalculator.astro - 紫微斗数排盘计算器（完整版：农历+三宫四正+飞宫四化）
---

<div class="chart-calc-wrapper">
  <div class="chart-calc">
    <div class="calc-header">
      <div class="calc-icon">✦</div>
      <h3>紫微斗数排盘</h3>
      <span class="solar-note">支持阳历/农历输入</span>
    </div>

    <div class="calc-fields">
      <div class="calc-row">
        <div class="calc-group">
          <label>历法类型</label>
          <select id="calc-calendar">
            <option value="solar">阳历（公历）</option>
            <option value="lunar">农历（阴历）</option>
          </select>
        </div>
      </div>
      
      <div class="calc-row">
        <div class="calc-group">
          <label for="calc-year">出生年份</label>
          <input type="number" id="calc-year" placeholder="例：1991" min="1900" max="2030" />
        </div>
        <div class="calc-group">
          <label for="calc-month">月份</label>
          <input type="number" id="calc-month" placeholder="1–12" min="1" max="12" />
        </div>
        <div class="calc-group">
          <label for="calc-day">日期</label>
          <input type="number" id="calc-day" placeholder="1–30" min="1" max="30" />
        </div>
      </div>

      <div class="calc-row">
        <div class="calc-group">
          <label for="calc-hour">出生时辰</label>
          <select id="calc-hour">
            <option value="">请选择时辰</option>
            <option value="0">子时 23:00–01:00</option>
            <option value="1">丑时 01:00–03:00</option>
            <option value="2">寅时 03:00–05:00</option>
            <option value="3">卯时 05:00–07:00</option>
            <option value="4">辰时 07:00–09:00</option>
            <option value="5">巳时 09:00–11:00</option>
            <option value="6">午时 11:00–13:00</option>
            <option value="7">未时 13:00–15:00</option>
            <option value="8">申时 15:00–17:00</option>
            <option value="9">酉时 17:00–19:00</option>
            <option value="10">戌时 19:00–21:00</option>
            <option value="11">亥时 21:00–23:00</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="calc-gender">性别</label>
          <select id="calc-gender">
            <option value="">请选择</option>
            <option value="male">男</option>
            <option value="female">女</option>
          </select>
        </div>
      </div>
    </div>

    <div class="calc-action">
      <button id="calc-btn">⭐ 生成命盘分析</button>
      <p id="calc-msg"></p>
    </div>

    <div id="calc-result">
      <div class="result-divider">◆ 命盘结果 ◆</div>

      <div class="result-block">
        <h4>命盘总览</h4>
        <div id="calc-summary"></div>
      </div>

      <div class="result-block">
        <h4>生年四化（本命盘）</h4>
        <div id="calc-sihua"></div>
      </div>

      <div class="result-block">
        <h4>十二宫命盘图</h4>
        <div id="calc-chart"></div>
      </div>

      <div class="result-block">
        <h4>大运流年</h4>
        <div id="calc-dayun"></div>
      </div>

      <div class="result-block">
        <h4>过去五年事件回溯</h4>
        <div id="calc-past"></div>
      </div>

      <div class="result-block">
        <h4>未来五年事件预测</h4>
        <div id="calc-future"></div>
      </div>
    </div>
  </div>
</div>

