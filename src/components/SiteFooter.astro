---
// Footer override: original Starlight footer + custom links
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';
const currentYear = new Date().getFullYear();
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />

	{
		config.credits && (
			<a class="kudos sl-flex" href="https://starlight.astro.build">
				<Icon name={'starlight'} /> {Astro.locals.t('builtWithStarlight.label')}
			</a>
		)
	}

	<div class="site-footer-custom">
		<div class="footer-links">
			<a href="/about">关于我们</a>
			<span class="footer-sep">|</span>
			<a href="/disclaimer">免责声明</a>
			<span class="footer-sep">|</span>
			<a href="/privacy">隐私政策</a>
			<span class="footer-sep">|</span>
			<a href="/contact">联系我们</a>
			<span class="footer-sep">|</span>
			<a href="/advertising">广告合作</a>
		</div>
		<div class="footer-friendlinks">
			<span class="fl-label">友情链接：</span>
			<a href="https://skillxm.cn" target="_blank" rel="noopener">skillxm.cn</a>
			<span class="fl-sep">|</span>
			<a href="https://tool.skillxm.cn" target="_blank" rel="noopener">tool.skillxm.cn</a>
			<span class="fl-sep">|</span>
			<a href="https://docs.skillxm.cn" target="_blank" rel="noopener">docs.skillxm.cn</a>
		</div>
		<div class="footer-copyright">
			&copy; {currentYear} 紫微斗数 · Zi Wei Dou Shu. All rights reserved.
		</div>
	</div>
</footer>

<style>
	@layer starlight.core {
		footer {
			flex-direction: column;
			gap: 1.5rem;
		}
		.meta {
			gap: 0.75rem 3rem;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}
		.meta > :global(p:only-child) {
			margin-inline-start: auto;
		}

		.kudos {
			align-items: center;
			gap: 0.5em;
			margin: 1.5rem auto;
			font-size: var(--sl-text-xs);
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		.kudos:hover {
			color: var(--sl-color-white);
		}
	}

	@layer starlight.components {
		.kudos :global(svg) {
			color: var(--sl-color-orange);
		}
	}

	.site-footer-custom {
		width: 100%;
		text-align: center;
		padding: 1.5rem 1.5rem 1rem;
		border-top: 1px solid var(--sl-color-gray-5);
		margin-top: 1rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 0.25rem 0.5rem;
		margin-bottom: 0.75rem;
	}

	.footer-links a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: var(--sl-text-sm);
		transition: color 0.2s;
	}

	.footer-links a:hover {
		color: var(--sl-color-text);
	}

	.footer-sep,
	.fl-sep {
		color: var(--sl-color-gray-5);
		font-size: var(--sl-text-xs);
	}

	.footer-friendlinks {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 0.25rem 0.5rem;
		margin-bottom: 0.75rem;
	}

	.fl-label {
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-xs);
	}

	.footer-friendlinks a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: var(--sl-text-xs);
		transition: color 0.2s;
	}

	.footer-friendlinks a:hover {
		color: var(--sl-color-text);
	}

	.footer-copyright {
		color: var(--sl-color-gray-4);
		font-size: var(--sl-text-xs);
		margin-top: 0.25rem;
	}
</style>
