---
// 紫微斗数排盘主组件
import { calculateZiWeiChart, generateTenYearFortune, type BirthInfo } from '../lib/ziping-calculator';
---

<div class="ziping-chart-container">
  <div class="chart-header">
    <h2>紫微斗数排盘 · 十年运势分析</h2>
    <p class="subtitle">输入您的出生信息，获取专属命盘与前十年回顾、未来十年预测</p>
  </div>

  <!-- 出生信息输入表单 -->
  <form id="birthInfoForm" class="birth-input-form">
    <div class="form-row">
      <div class="form-group">
        <label for="birthYear">出生年份</label>
        <input 
          type="number" 
          id="birthYear" 
          name="year" 
          min="1900" 
          max="2026" 
          placeholder="1990"
          required
        />
      </div>
      
      <div class="form-group">
        <label for="birthMonth">出生月份</label>
        <select id="birthMonth" name="month" required>
          <option value="">选择月份</option>
          <option value="1">正月 (农历一月)</option>
          <option value="2">二月</option>
          <option value="3">三月</option>
          <option value="4">四月</option>
          <option value="5">五月</option>
          <option value="6">六月</option>
          <option value="7">七月</option>
          <option value="8">八月</option>
          <option value="9">九月</option>
          <option value="10">十月</option>
          <option value="11">十一月</option>
          <option value="12">十二月</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="birthDay">出生日期</label>
        <input 
          type="number" 
          id="birthDay" 
          name="day" 
          min="1" 
          max="31" 
          placeholder="15"
          required
        />
      </div>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="birthHour">出生时辰</label>
        <select id="birthHour" name="hour" required>
          <option value="">选择时辰</option>
          <option value="0">子时 (23:00-01:00)</option>
          <option value="2">丑时 (01:00-03:00)</option>
          <option value="4">寅时 (03:00-05:00)</option>
          <option value="6">卯时 (05:00-07:00)</option>
          <option value="8">辰时 (07:00-09:00)</option>
          <option value="10">巳时 (09:00-11:00)</option>
          <option value="12">午时 (11:00-13:00)</option>
          <option value="14">未时 (13:00-15:00)</option>
          <option value="16">申时 (15:00-17:00)</option>
          <option value="18">酉时 (17:00-19:00)</option>
          <option value="20">戌时 (19:00-21:00)</option>
          <option value="22">亥时 (21:00-23:00)</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="gender">性别</label>
        <select id="gender" name="gender" required>
          <option value="">选择性别</option>
          <option value="male">男</option>
          <option value="female">女</option>
        </select>
      </div>
      
      <div class="form-group form-actions">
        <button type="submit" class="btn-primary">开始排盘</button>
      </div>
    </div>
  </form>

  <!-- 排盘结果展示区域 -->
  <div id="chartResult" class="chart-result" style="display: none;">
    <!-- 基本信息 -->
    <div class="basic-info">
      <h3>命盘基本信息</h3>
      <div class="info-grid">
        <div class="info-item">
          <span class="label">生辰八字：</span>
          <span class="value" id="eightChars"></span>
        </div>
        <div class="info-item">
          <span class="label">五行局：</span>
          <span class="value" id="fiveElementPhase"></span>
        </div>
        <div class="info-item">
          <span class="label">命宫位置：</span>
          <span class="value" id="lifePalace"></span>
        </div>
        <div class="info-item">
          <span class="label">身宫位置：</span>
          <span class="value" id="bodyPalace"></span>
        </div>
        <div class="info-item">
          <span class="label">当前年龄：</span>
          <span class="value" id="currentAge"></span>
        </div>
        <div class="info-item">
          <span class="label">当前大限：</span>
          <span class="value" id="currentDaXian"></span>
        </div>
      </div>
    </div>

    <!-- 十二宫位图 -->
    <div class="palace-chart">
      <h3>十二宫位命盘</h3>
      <div class="palace-grid">
        <!-- 通过 JavaScript 动态生成 -->
      </div>
    </div>

    <!-- 十四主星分布 -->
    <div class="stars-section">
      <h3>十四主星分布</h3>
      <div class="stars-grid" id="majorStarsGrid"></div>
    </div>

    <!-- 十年运势分析 -->
    <div class="fortune-section">
      <h3>十年运势分析</h3>
      
      <div class="fortune-tabs">
        <button class="tab-btn active" data-tab="past">前十年回顾</button>
        <button class="tab-btn" data-tab="future">未来十年预测</button>
      </div>
      
      <div class="tab-content">
        <div id="pastFortune" class="fortune-content active"></div>
        <div id="futureFortune" class="fortune-content"></div>
      </div>
    </div>
  </div>
</div>

<style>
.ziping-chart-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
  font-family: 'Noto Serif SC', serif;
}

.chart-header {
  text-align: center;
  margin-bottom: 2rem;
}

.chart-header h2 {
  font-size: 2rem;
  color: #c9a84c;
  margin-bottom: 0.5rem;
  font-family: 'Ma Shan Zheng', cursive;
}

.subtitle {
  color: #b8a888;
  font-size: 1.1rem;
}

/* 表单样式 */
.birth-input-form {
  background: linear-gradient(135deg, rgba(201, 168, 76, 0.05), transparent);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: 8px;
  padding: 2rem;
  margin-bottom: 2rem;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-group label {
  font-size: 0.95rem;
  color: #c9a84c;
  margin-bottom: 0.5rem;
  font-weight: 500;
}

.form-group input,
.form-group select {
  padding: 0.75rem;
  border: 1px solid rgba(201, 168, 76, 0.3);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.05);
  color: #e8c96e;
  font-size: 1rem;
  transition: all 0.3s ease;
}

.form-group input:focus,
.form-group select:focus {
  outline: none;
  border-color: #c9a84c;
  box-shadow: 0 0 8px rgba(201, 168, 76, 0.3);
}

.form-actions {
  justify-content: flex-end;
}

.btn-primary {
  background: linear-gradient(135deg, #c9a84c, #e8c96e);
  color: #1a1a1a;
  border: none;
  padding: 0.75rem 2rem;
  border-radius: 4px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: auto;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(201, 168, 76, 0.4);
}

/* 结果展示区域 */
.chart-result {
  animation: fadeIn 0.5s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.basic-info {
  background: rgba(201, 168, 76, 0.05);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 2rem;
}

.basic-info h3 {
  color: #c9a84c;
  margin-bottom: 1rem;
  font-size: 1.3rem;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1rem;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 0.75rem;
  border-bottom: 1px solid rgba(201, 168, 76, 0.1);
}

.info-item .label {
  color: #b8a888;
  font-weight: 500;
}

.info-item .value {
  color: #e8c96e;
  font-weight: 600;
}

/* 宫位图 */
.palace-chart {
  margin-bottom: 2rem;
}

.palace-chart h3 {
  color: #c9a84c;
  margin-bottom: 1rem;
  font-size: 1.3rem;
}

.palace-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.palace-cell {
  background: rgba(201, 168, 76, 0.08);
  border: 1px solid rgba(201, 168, 76, 0.2);
  border-radius: 6px;
  padding: 1rem;
  transition: all 0.3s ease;
}

.palace-cell:hover {
  background: rgba(201, 168, 76, 0.15);
  transform: translateY(-2px);
}

.palace-name {
  font-size: 1.1rem;
  color: #c9a84c;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.palace-branch {
  font-size: 0.9rem;
  color: #b8a888;
  margin-bottom: 0.5rem;
}

.palace-stars {
  font-size: 0.85rem;
  color: #e8c96e;
}

.star-tag {
  display: inline-block;
  background: rgba(201, 168, 76, 0.2);
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  margin: 0.2rem;
}

/* 星曜分布 */
.stars-section {
  margin-bottom: 2rem;
}

.stars-section h3 {
  color: #c9a84c;
  margin-bottom: 1rem;
  font-size: 1.3rem;
}

.stars-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.star-card {
  background: rgba(201, 168, 76, 0.08);
  border: 1px solid rgba(201, 168, 76, 0.2);
  border-radius: 6px;
  padding: 1rem;
  text-align: center;
}

.star-name {
  font-size: 1.2rem;
  color: #c9a84c;
  font-weight: 600;
  margin-bottom: 0.3rem;
}

.star-position {
  font-size: 0.85rem;
  color: #b8a888;
}

.star-brightness {
  font-size: 0.8rem;
  color: #e8c96e;
  margin-top: 0.3rem;
}

/* 运势分析 */
.fortune-section {
  background: rgba(201, 168, 76, 0.05);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: 8px;
  padding: 1.5rem;
}

.fortune-section h3 {
  color: #c9a84c;
  margin-bottom: 1rem;
  font-size: 1.3rem;
}

.fortune-tabs {
  display: flex;
  gap: 1rem;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid rgba(201, 168, 76, 0.15);
  padding-bottom: 1rem;
}

.tab-btn {
  background: transparent;
  border: 1px solid rgba(201, 168, 76, 0.3);
  color: #b8a888;
  padding: 0.75rem 1.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 1rem;
}

.tab-btn:hover {
  border-color: #c9a84c;
  color: #c9a84c;
}

.tab-btn.active {
  background: linear-gradient(135deg, #c9a84c, #e8c96e);
  color: #1a1a1a;
  border-color: #c9a84c;
  font-weight: 600;
}

.tab-content {
  position: relative;
}

.fortune-content {
  display: none;
  line-height: 1.8;
}

.fortune-content.active {
  display: block;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(-10px); }
  to { opacity: 1; transform: translateX(0); }
}

.fortune-content h2,
.fortune-content h3,
.fortune-content h4 {
  color: #c9a84c;
  margin: 1.5rem 0 0.8rem;
}

.fortune-content strong {
  color: #e8c96e;
}

.fortune-content ul {
  list-style: none;
  padding-left: 0;
}

.fortune-content li {
  padding: 0.5rem 0;
  color: #b8a888;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .ziping-chart-container {
    padding: 1rem;
  }
  
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .palace-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .info-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
  // 客户端交互逻辑
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('birthInfoForm') as HTMLFormElement;
    const chartResult = document.getElementById('chartResult');
    
    form?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData(form);
      const birthInfo: BirthInfo = {
        year: parseInt(formData.get('year') as string),
        month: parseInt(formData.get('month') as string),
        day: parseInt(formData.get('day') as string),
        hour: parseInt(formData.get('hour') as string),
        gender: formData.get('gender') as 'male' | 'female'
      };
      
      // 调用排盘 API（这里需要实际的后端支持或使用 WebAssembly）
      // 简化示例：直接显示结果
      displayChartResult(birthInfo);
    });
    
    // Tab 切换
    const tabBtns = document.querySelectorAll('.tab-btn');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const tabName = (btn as HTMLElement).dataset.tab;
        document.querySelectorAll('.fortune-content').forEach(content => {
          content.classList.remove('active');
        });
        document.getElementById(tabName + 'Fortune')?.classList.add('active');
      });
    });
  });
  
  function displayChartResult(birthInfo: BirthInfo) {
    // 这里需要导入并调用 calculateZiWeiChart 和 generateTenYearFortune
    // 由于 Astro 的限制，实际实现需要通过 API 端点或 WebAssembly
    
    // 模拟显示结果
    const chartResult = document.getElementById('chartResult');
    if (chartResult) {
      chartResult.style.display = 'block';
      
      // 填充基本信息
      document.getElementById('eightChars')!.textContent = `${birthInfo.year}年 ${birthInfo.month}月 ${birthInfo.day}日 ${birthInfo.hour}时`;
      document.getElementById('fiveElementPhase')!.textContent = '计算中...';
      document.getElementById('lifePalace')!.textContent = '计算中...';
      document.getElementById('currentAge')!.textContent = String(new Date().getFullYear() - birthInfo.year);
      
      // 滚动到结果区域
      chartResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
</script>
